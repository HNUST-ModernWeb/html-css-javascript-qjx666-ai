<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>个人信息卡片</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Microsoft YaHei", sans-serif;
        }

        body {
            background-color: #bedfe4;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            padding: 40px 20px;
        }

        h1 {
            color: #2c3e50;
            margin-bottom: 30px;
            font-size: 28px;
        }

        .card {
            background: white;
            width: 100%;
            max-width: 420px;
            padding: 35px;
            border-radius: 16px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }

        .avatar-wrapper {
            position: relative;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            overflow: hidden;
            border: 3px solid #e4e7ed;
            cursor: pointer;
        }

        #avatar {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .avatar-label {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.5);
            color: white;
            text-align: center;
            font-size: 12px;
            padding: 4px 0;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .avatar-wrapper:hover .avatar-label {
            opacity: 1;
        }

        #avatar-input {
            display: none;
        }

        .info-item {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .info-item label {
            font-size: 14px;
            color: #606266;
        }

        .info-item input,
        .info-item textarea {
            padding: 10px 12px;
            border: 1px solid #dcdfe6;
            border-radius: 8px;
            font-size: 15px;
            transition: border-color 0.3s;
            resize: none;
        }

        .info-item input:focus,
        .info-item textarea:focus {
            outline: none;
            border-color: #409eff;
        }

        #save-btn {
            width: 100%;
            padding: 12px;
            background-color: #409eff;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            cursor: pointer;
            transition: background-color 0.3s;
        }

        #save-btn:hover {
            background-color: #337ecc;
        }

        .display-info {
            width: 100%;
            text-align: center;
            margin-top: 10px;
        }

        .display-name {
            font-size: 22px;
            font-weight: bold;
            color: #303133;
            margin-bottom: 8px;
        }

        .display-bio {
            font-size: 14px;
            color: #606266;
            line-height: 1.5;
        }
    </style>
</head>
<body>
    <h1>个人信息卡片</h1>
    <div class="card">
        <!-- 头像上传区域 -->
        <div class="avatar-wrapper">
            <img id="avatar" src="https://picsum.photos/200/200" alt="头像">
            <div class="avatar-label">点击更换头像</div>
            <input type="file" id="avatar-input" accept="image/*">
        </div>

        <!-- 编辑区域 -->
        <div class="info-item">
            <label for="name">姓名（可编辑）</label>
            <input type="text" id="name" placeholder="请输入你的姓名" value="张三">
        </div>
        <div class="info-item">
            <label for="bio">个人简介（可编辑）</label>
            <textarea id="bio" rows="3" placeholder="请输入你的个人简介">热爱前端开发，喜欢探索新技术~</textarea>
        </div>

        <!-- 保存按钮 -->
        <button id="save-btn">保存</button>

        <!-- 信息展示区域 -->
        <div class="display-info">
            <div class="display-name" id="display-name">张三</div>
            <div class="display-bio" id="display-bio">热爱前端开发，喜欢探索新技术~</div>
        </div>
    </div>

    <script>
        // 获取DOM元素
        const avatarInput = document.getElementById('avatar-input');
        const avatarImg = document.getElementById('avatar');
        const nameInput = document.getElementById('name');
        const bioInput = document.getElementById('bio');
        const saveBtn = document.getElementById('save-btn');
        const displayName = document.getElementById('display-name');
        const displayBio = document.getElementById('display-bio');
        const avatarWrapper = document.querySelector('.avatar-wrapper');

        // 1. 头像上传与预览
        avatarWrapper.addEventListener('click', () => {
            avatarInput.click();
        });

        avatarInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (event) => {
                    avatarImg.src = event.target.result;
                };
                reader.readAsDataURL(file);
            }
        });

        // 2. 保存功能：更新展示信息
        saveBtn.addEventListener('click', () => {
            const newName = nameInput.value.trim() || '未设置姓名';
            const newBio = bioInput.value.trim() || '未设置个人简介';
            
            displayName.textContent = newName;
            displayBio.textContent = newBio;
            
            // 可选：添加保存成功提示
            alert('信息已保存！');
        });
    </script>
</body>
</html>